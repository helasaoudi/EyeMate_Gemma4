# EyeMate Backend Configuration

# Server Settings
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Model Configuration
GEMMA4_MODEL_NAME=google/gemma-4-E4B-it
MAX_NEW_TOKENS_SCENE=1024
MAX_NEW_TOKENS_DOCUMENT=2048

# ==========================================
# vLLM Engine (RECOMMENDED for Production)
# ==========================================
# Enable vLLM for 2-5x faster inference and 50% less GPU memory
USE_VLLM=true

# GPU Memory Utilization (0.0-1.0)
# Use 90% of GPU memory - adjust if you get OOM errors
VLLM_GPU_MEMORY_UTILIZATION=0.90

# Tensor Parallelism (number of GPUs)
# Set to 1 for single GPU, 2 for dual GPU, etc.
VLLM_TENSOR_PARALLEL_SIZE=1

# Data Type (auto, float16, bfloat16, float32)
# auto = bfloat16 on Ampere+ GPUs, float16 on older GPUs
VLLM_DTYPE=auto

# Enable chunked prefill for better throughput with long contexts
VLLM_ENABLE_CHUNKED_PREFILL=true

# Enable prefix caching to reuse KV cache for repeated prompts
VLLM_ENABLE_PREFIX_CACHING=true

# Enforce eager mode (disable CUDA graphs)
# Set to true for debugging, false for production
VLLM_ENFORCE_EAGER=false

# Maximum model sequence length
# Reduce this if you get OOM errors (e.g., 4096)
VLLM_MAX_MODEL_LEN=8192

# ==========================================
# Standard Transformers Settings (Fallback)
# ==========================================
# Only used when USE_VLLM=false

# torch dtype: bfloat16 on CUDA, float32 on CPU
TORCH_DTYPE=bfloat16

# Device mapping strategy
DEVICE_MAP=auto

# Attention implementation (eager, sdpa, flash_attention_2)
# flash_attention_2 requires: pip install flash-attn --no-build-isolation
ATTN_IMPLEMENTATION=sdpa
