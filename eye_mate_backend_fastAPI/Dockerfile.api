# FastAPI Backend Dockerfile for DGX Spark
# This runs the API layer that connects to vLLM container

FROM python:3.12-slim

WORKDIR /app

# Install dependencies
COPY requirements-api.txt .
RUN pip install --no-cache-dir -r requirements-api.txt

# Copy application code
COPY app ./app
COPY main.py .

# Expose port
EXPOSE 8080

# Run FastAPI server
CMD ["python", "main.py"]
